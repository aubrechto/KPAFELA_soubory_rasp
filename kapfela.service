[Unit]
Description=KAPFELA dashboard
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/KPAFELA_soubory_rasp
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=append:/var/log/kapfela.log
StandardError=append:/var/log/kapfela.err

[Install]
WantedBy=multi-user.target
